<% activities = risk.activities.by_planned_date %>
<% manage_activities = User.current.allowed_to?(:manage_risk_activities, risk.project) %>

<div class="contextual">
  <% if manage_activities %>
    <%= link_to l(:label_risk_activity_new), new_risk_activity_path(risk), class: 'icon icon-add' %>
  <% end %>
</div>

<p><strong><%= l(:label_risk_activities) %></strong></p>

<% if activities.any? %>
  <% open_activities = activities.select(&:open?) %>
  <% completed_activities = activities.select { |a| a.completed? || a.cancelled? } %>
  <% overdue_count = activities.count(&:overdue?) %>

  <div class="activities-stats-bar">
    <span class="stat-badge total"><%= activities.count %> <%= l(:label_total) %></span>
    <span class="stat-badge open"><%= open_activities.count %> <%= l(:label_open) %></span>
    <span class="stat-badge completed"><%= completed_activities.count %> <%= l(:label_completed) %></span>
    <% if overdue_count > 0 %>
      <span class="stat-badge overdue"><%= overdue_count %> <%= l(:label_overdue) %></span>
    <% end %>
  </div>

  <table class="list activities-table">
    <thead>
      <tr>
        <th><%= l(:field_activity_type) %></th>
        <th><%= l(:field_subject) %></th>
        <th><%= l(:field_status) %></th>
        <th><%= l(:field_assigned_to) %></th>
        <th><%= l(:field_planned_date) %></th>
        <% if manage_activities %>
          <th></th>
        <% end %>
      </tr>
    </thead>
    <tbody>
      <% activities.each do |activity| %>
        <tr class="activity-row <%= activity.status %> <%= 'overdue' if activity.overdue? %>">
          <td>
            <span class="activity-type-badge <%= activity.activity_type %>">
              <%= l("label_risk_activity_type_#{activity.activity_type}") %>
            </span>
          </td>
          <td class="subject">
            <%= link_to activity.subject, risk_activity_path(risk, activity) %>
            <% if activity.notes.any? %>
              <span class="note-count" title="<%= l(:label_updates) %>">(<%= activity.notes.count %>)</span>
            <% end %>
          </td>
          <td>
            <span class="activity-status-badge <%= activity.status %>">
              <%= l("label_risk_activity_status_#{activity.status}") %>
            </span>
          </td>
          <td><%= activity.assigned_to ? link_to_user(activity.assigned_to) : "-" %></td>
          <td class="<%= 'overdue-date' if activity.overdue? %>">
            <% if activity.planned_date %>
              <%= format_date(activity.planned_date) %>
              <% if activity.open? && activity.days_until_due %>
                <% days = activity.days_until_due %>
                <br><small class="<%= days < 0 ? 'overdue' : (days <= 7 ? 'soon' : '') %>">
                  <%= days < 0 ? l(:label_overdue_by, :count => days.abs) : l(:label_due_in, :count => days) %>
                </small>
              <% end %>
            <% else %>
              -
            <% end %>
          </td>
          <% if manage_activities %>
            <td class="buttons">
              <%= link_to '', edit_risk_activity_path(risk, activity), class: 'icon-only icon-edit', title: l(:button_edit) %>
              <%= link_to '', risk_activity_path(risk, activity), method: :delete, data: { confirm: l(:text_are_you_sure) }, class: 'icon-only icon-del', title: l(:button_delete) %>
            </td>
          <% end %>
        </tr>
      <% end %>
    </tbody>
  </table>
<% elsif manage_activities %>
  <p class="nodata"><%= l(:label_no_data) %></p>
<% end %>
