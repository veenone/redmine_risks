<div class="contextual">
  <%= link_to l(:button_cancel), project_risks_path(@project), :class => 'icon icon-cancel' %>
</div>

<%= title l(:label_new_risk) %>

<%= call_hook(:view_risk_new_top, {:risk => @risk}) %>

<%= labelled_form_for @risk, :url => project_risks_path(@project), :html => {:id => 'risk-form'} do |f| %>
  <%= error_messages_for 'risk' %>
  <div class="box tabular">
    <div id="all_attributes">
      <%= render :partial => 'form', :locals => {:f => f} %>
    </div>
  </div>

  <div class="form-actions">
    <%= submit_tag l(:button_create), :class => 'btn btn-primary' %>
    <%= submit_tag l(:button_create_and_continue), :name => 'continue', :class => 'btn' %>
    <% if Redmine::VERSION.to_s < '4.0' %>
      <%= preview_link preview_new_risk_path(:project_id => @risk.project), 'risk-form' %>
    <% end %>
    <%= link_to l(:button_cancel), project_risks_path(@project), :class => 'btn btn-link' %>
  </div>
<% end %>

<% if Redmine::VERSION.to_s < '4.0' %>
  <div id="preview" class="wiki"></div>
<% end %>

<% content_for :header_tags do %>
  <%= robot_exclusion_tag %>
  <%= stylesheet_link_tag 'risks', :plugin => 'redmine_risks' %>
<% end %>

