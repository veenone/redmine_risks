<%= render :partial => 'action_menu' %>

<h2><%= l(:label_risk) %> <%= @risk.risk_id_code.present? ? @risk.risk_id_code : "##{@risk.id}" %></h2>

<div class="<%= @risk.css_classes %> risk-details">
  <div class="subject">
    <h3><%= @risk.subject %></h3>
  </div>

  <p class="author">
    <%= authoring @risk.created_on, @risk.author %>.
    <% if @risk.created_on != @risk.updated_on %>
      <%= l(:label_updated_time, time_tag(@risk.updated_on)).html_safe %>.
    <% end %>
  </p>

  <%# Section 1: Risk Identification %>
  <fieldset class="risk-section collapsible" id="show-identification">
    <legend onclick="toggleSection('show-identification')"><%= l(:label_risk_identification) %></legend>
    <div class="section-content">
      <div class="attributes-grid">
        <div class="attribute-item">
          <span class="attribute-label"><%= l(:field_risk_id_code) %></span>
          <span class="attribute-value"><%= @risk.risk_id_code.present? ? @risk.risk_id_code : "-" %></span>
        </div>
        <div class="attribute-item">
          <span class="attribute-label"><%= l(:field_status) %></span>
          <span class="attribute-value status <%= @risk.status %>"><%= format_risk_status(@risk.status) %></span>
        </div>
        <div class="attribute-item">
          <span class="attribute-label"><%= l(:field_risk_category_entry) %></span>
          <span class="attribute-value"><%= @risk.risk_category_entry ? @risk.risk_category_entry.name : "-" %></span>
        </div>
        <div class="attribute-item">
          <span class="attribute-label"><%= l(:field_risk_registry) %></span>
          <span class="attribute-value"><%= @risk.risk_registry ? @risk.risk_registry.name : "-" %></span>
        </div>
        <div class="attribute-item">
          <span class="attribute-label"><%= l(:field_risk_area) %></span>
          <span class="attribute-value"><%= @risk.risk_area ? @risk.risk_area.name : "-" %></span>
        </div>
        <% if @risk.category.present? %>
          <div class="attribute-item">
            <span class="attribute-label"><%= l(:field_category) %> (Legacy)</span>
            <span class="attribute-value"><%= @risk.category.name %></span>
          </div>
        <% end %>
      </div>

      <% if @risk.threat_event.present? %>
        <div class="detail-block">
          <div class="detail-header">
            <strong><%= l(:field_threat_event) %></strong>
          </div>
          <div class="wiki">
            <%= textilizable @risk, :threat_event %>
          </div>
        </div>
      <% end %>
    </div>
  </fieldset>

  <%# Section 2: Risk Ownership %>
  <fieldset class="risk-section collapsible" id="show-ownership">
    <legend onclick="toggleSection('show-ownership')"><%= l(:label_risk_ownership) %></legend>
    <div class="section-content">
      <div class="attributes-grid two-columns">
        <div class="attribute-item">
          <span class="attribute-label"><%= l(:field_risk_owner) %></span>
          <span class="attribute-value"><%= @risk.risk_owner ? link_to_user(@risk.risk_owner) : "-" %></span>
        </div>
        <div class="attribute-item">
          <span class="attribute-label"><%= l(:field_assigned_to) %></span>
          <span class="attribute-value"><%= @risk.assigned_to ? link_to_user(@risk.assigned_to) : "-" %></span>
        </div>
        <div class="attribute-item">
          <span class="attribute-label"><%= l(:field_action_owner) %></span>
          <span class="attribute-value"><%= @risk.action_owner ? link_to_user(@risk.action_owner) : "-" %></span>
        </div>
        <div class="attribute-item">
          <span class="attribute-label"><%= l(:field_owner) %></span>
          <span class="attribute-value"><%= @risk.owner ? link_to_user(@risk.owner) : "-" %></span>
        </div>
      </div>
    </div>
  </fieldset>

  <%# Section 3: Impacted Assets (Multi-entry) %>
  <% if @risk.risk_assets.any? %>
    <fieldset class="risk-section collapsible" id="show-assets">
      <legend onclick="toggleSection('show-assets')"><%= l(:label_impacted_assets) %> (<%= @risk.risk_assets.count %>)</legend>
      <div class="section-content">
        <table class="list multi-entry-list">
          <thead>
            <tr>
              <th><%= l(:field_name) %></th>
              <th><%= l(:field_description) %></th>
            </tr>
          </thead>
          <tbody>
            <% @risk.risk_assets.sorted.each do |asset| %>
              <tr class="<%= cycle('odd', 'even') %>">
                <td><%= asset.name %></td>
                <td><%= asset.description %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </fieldset>
  <% end %>

  <%# Section 4: Vulnerabilities (Multi-entry) %>
  <% if @risk.risk_vulnerabilities.any? %>
    <fieldset class="risk-section collapsible" id="show-vulnerabilities">
      <legend onclick="toggleSection('show-vulnerabilities')"><%= l(:label_vulnerabilities) %> (<%= @risk.risk_vulnerabilities.count %>)</legend>
      <div class="section-content">
        <table class="list multi-entry-list">
          <thead>
            <tr>
              <th><%= l(:field_name) %></th>
              <th><%= l(:field_description) %></th>
            </tr>
          </thead>
          <tbody>
            <% @risk.risk_vulnerabilities.sorted.each do |vuln| %>
              <tr class="<%= cycle('odd', 'even') %>">
                <td><%= vuln.name %></td>
                <td><%= vuln.description %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </fieldset>
  <% end %>

  <%# Section 5: Consequences (Multi-entry) %>
  <% if @risk.risk_consequences.any? %>
    <fieldset class="risk-section collapsible" id="show-consequences">
      <legend onclick="toggleSection('show-consequences')"><%= l(:label_consequences) %> (<%= @risk.risk_consequences.count %>)</legend>
      <div class="section-content">
        <table class="list multi-entry-list">
          <thead>
            <tr>
              <th><%= l(:field_name) %></th>
              <th><%= l(:field_description) %></th>
            </tr>
          </thead>
          <tbody>
            <% @risk.risk_consequences.sorted.each do |consequence| %>
              <tr class="<%= cycle('odd', 'even') %>">
                <td><%= consequence.name %></td>
                <td><%= consequence.description %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </fieldset>
  <% end %>

  <%# Section 6: Counter-measures (Multi-entry) %>
  <% if @risk.risk_counter_measures.any? %>
    <fieldset class="risk-section collapsible" id="show-counter-measures">
      <legend onclick="toggleSection('show-counter-measures')"><%= l(:label_counter_measures) %> (<%= @risk.risk_counter_measures.count %>)</legend>
      <div class="section-content">
        <table class="list multi-entry-list">
          <thead>
            <tr>
              <th><%= l(:field_name) %></th>
              <th><%= l(:field_description) %></th>
            </tr>
          </thead>
          <tbody>
            <% @risk.risk_counter_measures.sorted.each do |measure| %>
              <tr class="<%= cycle('odd', 'even') %>">
                <td><%= measure.name %></td>
                <td><%= measure.description %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </fieldset>
  <% end %>

  <%# Section 7: CIA Assessment %>
  <% risk_project_setting = RiskProjectSetting.for_project(@risk.project) %>
  <fieldset class="risk-section collapsible" id="show-cia-assessment">
    <legend onclick="toggleSection('show-cia-assessment')"><%= l(:label_risk_cia_assessment) %></legend>
    <div class="section-content">
      <% if risk_project_setting.boolean_cia_mode? %>
        <p class="cia-mode-indicator"><em class="info"><%= l(:text_cia_boolean_mode_active) %></em></p>
      <% end %>
      <div class="cia-display">
        <div class="cia-item-display confidentiality">
          <div class="cia-header-display">
            <span class="cia-icon">C</span>
            <span class="cia-label"><%= l(:field_confidentiality) %></span>
          </div>
          <span class="cia-value">
            <%= @risk.cia_display_value(:confidentiality) || "-" %>
          </span>
        </div>

        <div class="cia-item-display integrity">
          <div class="cia-header-display">
            <span class="cia-icon">I</span>
            <span class="cia-label"><%= l(:field_integrity) %></span>
          </div>
          <span class="cia-value">
            <%= @risk.cia_display_value(:integrity) || "-" %>
          </span>
        </div>

        <div class="cia-item-display availability">
          <div class="cia-header-display">
            <span class="cia-icon">A</span>
            <span class="cia-label"><%= l(:field_availability) %></span>
          </div>
          <span class="cia-value">
            <%= @risk.cia_display_value(:availability) || "-" %>
          </span>
        </div>
      </div>
    </div>
  </fieldset>

  <%# Section 8: Risk Assessment (Impact & Probability) %>
  <fieldset class="risk-section collapsible" id="show-risk-assessment">
    <legend onclick="toggleSection('show-risk-assessment')"><%= l(:label_risk_assessment) %></legend>
    <div class="section-content">
      <div class="significance-display">
        <div class="significance-item-display">
          <span class="attribute-label"><%= l(:field_impact_point) %></span>
          <span class="attribute-value significance-point">
            <%= @risk.impact_point.present? ? Risk.impact_point_label(@risk.impact_point) : "-" %>
          </span>
          <% if @risk.impact_point.present? %>
            <span class="attribute-description"><%= Risk.impact_point_description(@risk.impact_point) %></span>
          <% end %>
        </div>

        <div class="significance-item-display">
          <span class="attribute-label"><%= l(:field_probability_point) %></span>
          <span class="attribute-value significance-point">
            <%= @risk.probability_point.present? ? Risk.probability_point_label(@risk.probability_point) : "-" %>
          </span>
          <% if @risk.probability_point.present? %>
            <span class="attribute-description"><%= Risk.probability_point_description(@risk.probability_point) %></span>
          <% end %>
        </div>

        <div class="significance-result-display">
          <div class="result-box">
            <span class="result-label"><%= l(:field_level_of_significance) %></span>
            <span class="significance-value <%= get_significance_class(@risk.level_of_significance) %>">
              <%= @risk.level_of_significance.present? ? @risk.level_of_significance : "-" %>
            </span>
          </div>
        </div>
      </div>

      <div class="attributes-grid" style="margin-top: 15px;">
        <div class="attribute-item">
          <span class="attribute-label"><%= l(:field_probability) %></span>
          <span class="attribute-value"><%= @risk.probability.present? ? format_risk_probability(@risk.probability) : "-" %></span>
        </div>
        <div class="attribute-item">
          <span class="attribute-label"><%= l(:field_impact) %></span>
          <span class="attribute-value"><%= @risk.impact.present? ? format_risk_impact(@risk.impact) : "-" %></span>
        </div>
        <div class="attribute-item">
          <span class="attribute-label"><%= l(:field_magnitude) %></span>
          <span class="attribute-value">
            <% if @risk.probability.present? && @risk.impact.present? %>
              <span class="magnitude-badge <%= @risk.magnitude.to_s.downcase %>"><%= @risk.magnitude %></span>
            <% else %>
              -
            <% end %>
          </span>
        </div>
        <div class="attribute-item">
          <span class="attribute-label"><%= l(:field_strategy) %></span>
          <span class="attribute-value"><%= @risk.strategy.present? ? format_risk_strategy(@risk.strategy) : "-" %></span>
        </div>
      </div>
    </div>
  </fieldset>

  <%# Section 9: Risk Treatment %>
  <fieldset class="risk-section collapsible" id="show-risk-treatment">
    <legend onclick="toggleSection('show-risk-treatment')"><%= l(:label_risk_treatment) %></legend>
    <div class="section-content">
      <div class="attributes-grid two-columns">
        <div class="attribute-item">
          <span class="attribute-label"><%= l(:field_risk_treatment_plan) %></span>
          <span class="attribute-value">
            <% if @risk.risk_treatment_plan.present? %>
              <span class="treatment-plan-badge <%= @risk.risk_treatment_plan %>">
                <%= l("label_risk_treatment_plan_#{@risk.risk_treatment_plan}") %>
              </span>
            <% else %>
              -
            <% end %>
          </span>
        </div>
        <div class="attribute-item">
          <span class="attribute-label"><%= l(:field_risk_treatment_owner) %></span>
          <span class="attribute-value"><%= @risk.risk_treatment_owner ? link_to_user(@risk.risk_treatment_owner) : "-" %></span>
        </div>
      </div>

      <% if @risk.risk_treatment.present? %>
        <div class="detail-block">
          <div class="detail-header">
            <strong><%= l(:field_risk_treatment) %></strong>
          </div>
          <div class="wiki">
            <%= textilizable @risk, :risk_treatment %>
          </div>
        </div>
      <% end %>
    </div>
  </fieldset>

  <%# Section 10: Mitigations (Multi-entry) %>
  <% if @risk.risk_mitigations.any? %>
    <fieldset class="risk-section collapsible" id="show-mitigations">
      <legend onclick="toggleSection('show-mitigations')"><%= l(:label_mitigations) %> (<%= @risk.risk_mitigations.count %>)</legend>
      <div class="section-content">
        <table class="list multi-entry-list">
          <thead>
            <tr>
              <th><%= l(:field_name) %></th>
              <th><%= l(:field_description) %></th>
            </tr>
          </thead>
          <tbody>
            <% @risk.risk_mitigations.sorted.each do |mitigation| %>
              <tr class="<%= cycle('odd', 'even') %>">
                <td><%= mitigation.name %></td>
                <td><%= mitigation.description %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </fieldset>
  <% end %>

  <%# Section 11: Preventions (Multi-entry) %>
  <% if @risk.risk_preventions.any? %>
    <fieldset class="risk-section collapsible" id="show-preventions">
      <legend onclick="toggleSection('show-preventions')"><%= l(:label_preventions) %> (<%= @risk.risk_preventions.count %>)</legend>
      <div class="section-content">
        <table class="list multi-entry-list">
          <thead>
            <tr>
              <th><%= l(:field_name) %></th>
              <th><%= l(:field_description) %></th>
            </tr>
          </thead>
          <tbody>
            <% @risk.risk_preventions.sorted.each do |prevention| %>
              <tr class="<%= cycle('odd', 'even') %>">
                <td><%= prevention.name %></td>
                <td><%= prevention.description %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </fieldset>
  <% end %>

  <%# Section 12: Remark %>
  <% if @risk.remark.present? || @risk.lessons.present? %>
    <fieldset class="risk-section collapsible" id="show-remark">
      <legend onclick="toggleSection('show-remark')"><%= l(:label_remark) %></legend>
      <div class="section-content">
        <% if @risk.remark.present? %>
          <div class="detail-block">
            <div class="detail-header">
              <strong><%= l(:field_remark) %></strong>
            </div>
            <div class="wiki">
              <%= textilizable @risk, :remark %>
            </div>
          </div>
        <% end %>

        <% if @risk.lessons.present? %>
          <div class="detail-block">
            <div class="detail-header">
              <strong><%= l(:field_lessons) %></strong>
            </div>
            <div class="wiki">
              <%= textilizable @risk, :lessons %>
            </div>
          </div>
        <% end %>
      </div>
    </fieldset>
  <% end %>

  <%# Description %>
  <% if @risk.description? %>
    <fieldset class="risk-section collapsible" id="show-details">
      <legend onclick="toggleSection('show-details')"><%= l(:label_details) %></legend>
      <div class="section-content">
        <div class="detail-block description">
          <div class="detail-header">
            <strong><%= l(:field_description) %></strong>
            <div class="contextual">
              <%= link_to l(:button_quote), quoted_risk_path(@risk), :remote => true, :method => 'post', :class => 'icon icon-comment' if @risk.notes_addable? %>
            </div>
          </div>
          <div class="wiki">
            <%= textilizable @risk, :description %>
          </div>
        </div>
      </div>
    </fieldset>
  <% end %>
</div>

<div id="relations" class="risk-section box">
  <%= render :partial => 'relations' %>
</div>

<div id="risk-activities-container" class="risk-section box">
  <%= render :partial => 'activities', :locals => { :risk => @risk } %>
</div>

<% if @journals.present? %>
  <div id="history">
    <h3><%= l(:label_history) %></h3>
    <%= render :partial => 'history', :locals => { :risk => @risk, :journals => @journals } %>
  </div>
<% end %>

<div style="clear: both;"></div>

<%= render :partial => 'action_menu' %>

<% if @risk.editable? %>
  <div id="update" style="display:none;">
    <h3><%= l(:button_edit) %></h3>
    <%= render :partial => 'edit' %>
  </div>
<% end %>

<% html_title l(:label_risk) + " ##{@risk.id}: #{@risk.subject}" %>

<%= context_menu %>

<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'risks', :plugin => 'redmine_risks' %>
  <%= stylesheet_link_tag 'risk_activities', :plugin => 'redmine_risks' %>
<% end %>

<script type="text/javascript">
  function toggleSection(sectionId) {
    var section = document.getElementById(sectionId);
    if (section) {
      section.classList.toggle('collapsed');
    }
  }
</script>
