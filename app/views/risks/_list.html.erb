<% query_options = nil unless defined?(query_options) %>
<% query_options ||= {} %>
<% can_delete = User.current.allowed_to?(:delete_risks, @project) %>

<%= form_tag({}, :data => {:cm_url => risks_context_menu_path}) do -%>
  <%= hidden_field_tag 'back_url', url_for(:params => request.query_parameters), :id => nil %>

  <div class="autoscroll">
    <table class="list risks odd-even <%= query.css_classes %>">
      <thead>
      <tr>
        <th class="checkbox hide-when-print">
          <%= check_box_tag 'check_all', '', false, :class => 'toggle-selection',
                            :title => "#{l(:button_check_all)}/#{l(:button_uncheck_all)}" %>
        </th>
        <% query.inline_columns.each do |column| %>
          <%= column_header(query, column, query_options) %>
        <% end %>
        <th class="actions hide-when-print"><%= l(:label_actions) %></th>
      </tr>
      </thead>
      <tbody>
      <% grouped_query_results(risks, query) do |risk, group_name, group_count, group_totals| -%>
        <% if group_name %>
          <% reset_cycle %>
          <tr class="group open">
            <td colspan="<%= query.inline_columns.size + 2 %>">
              <span class="expander" onclick="toggleRowGroup(this);">&nbsp;</span>
              <span class="name"><%= group_name %></span> <span class="count"><%= group_count %></span> <span class="totals"><%= group_totals %></span>
              <%= link_to_function("#{l(:button_collapse_all)}/#{l(:button_expand_all)}",
                                   "toggleAllRowGroups(this)", :class => 'toggle-all') %>
            </td>
          </tr>
        <% end %>
        <tr id="risk-<%= risk.id %>" class="hascontextmenu <%= cycle('odd', 'even') %> <%= risk.css_classes %>">
          <td class="checkbox hide-when-print"><%= check_box_tag("ids[]", risk.id, false, :id => nil) %></td>
          <% query.inline_columns.each do |column| %>
            <%= content_tag('td', column_content(column, risk), :class => column.css_classes) %>
          <% end %>
          <td class="actions hide-when-print">
            <%= link_to '', edit_risk_path(risk), :class => 'icon-only icon-edit', :title => l(:button_edit) if risk.editable? %>
            <% if risk.deletable? %>
              <%= link_to '', risk_path(risk),
                          :method => :delete,
                          :data => { :confirm => l(:text_risk_destroy_confirmation) },
                          :class => 'icon-only icon-del',
                          :title => l(:button_delete) %>
            <% end %>
          </td>
        </tr>
        <% query.block_columns.each do |column| -%>
          <% if (text = column_content(column, risk)) && text.present? -%>
            <tr class="<%= current_cycle %>">
              <td colspan="<%= query.inline_columns.size + 2 %>" class="<%= column.css_classes %>">
                <% if query.block_columns.count > 1 %>
                  <span><%= column.caption %></span>
                <% end %>
                <%= text %>
              </td>
            </tr>
          <% end -%>
        <% end -%>
      <% end -%>
      </tbody>
    </table>
  </div>

  <% if can_delete %>
    <div class="bulk-actions hide-when-print">
      <%= submit_tag l(:button_delete_selected),
                     :name => 'delete_selected',
                     :class => 'icon icon-del',
                     :data => { :confirm => l(:text_risks_destroy_confirmation) },
                     :formaction => risks_path,
                     :formmethod => 'delete' %>
    </div>
  <% end %>
<% end -%>
