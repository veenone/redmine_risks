<script type="text/html" id="risk_mitigation_template">
  <div class="multi-entry-row">
    <input type="text" name="risk[risk_mitigations_attributes][NEW_INDEX][name]" placeholder="<%= l(:field_name) %>" class="multi-entry-name" />
    <input type="text" name="risk[risk_mitigations_attributes][NEW_INDEX][description]" placeholder="<%= l(:field_description) %>" class="multi-entry-description" />
    <a href="#" class="icon icon-del remove-multi-entry"><%= l(:button_delete) %></a>
  </div>
</script>

<script type="text/html" id="risk_prevention_template">
  <div class="multi-entry-row">
    <input type="text" name="risk[risk_preventions_attributes][NEW_INDEX][name]" placeholder="<%= l(:field_name) %>" class="multi-entry-name" />
    <input type="text" name="risk[risk_preventions_attributes][NEW_INDEX][description]" placeholder="<%= l(:field_description) %>" class="multi-entry-description" />
    <a href="#" class="icon icon-del remove-multi-entry"><%= l(:button_delete) %></a>
  </div>
</script>

<script type="text/javascript">
  var probabilityDescriptions = <%= raw Risk::PROBABILITY_POINT_MAPPING.transform_values { |v| I18n.t("label_risk_probability_point_#{v[:key]}_desc", default: '') }.to_json %>;
  var impactDescriptions = <%= raw Risk::IMPACT_POINT_MAPPING.transform_values { |v| I18n.t("label_risk_impact_point_#{v[:key]}_desc", default: '') }.to_json %>;
  var multiEntryIndex = <%= Time.now.to_i %>;

  document.addEventListener('DOMContentLoaded', function() {
    // Add multi-entry row
    document.querySelectorAll('.add-multi-entry').forEach(function(link) {
      link.addEventListener('click', function(e) {
        e.preventDefault();
        var containerId = this.getAttribute('data-container');
        var templateId = this.getAttribute('data-template');
        var container = document.getElementById(containerId);
        var template = document.getElementById(templateId);

        if (container && template) {
          var html = template.innerHTML.replace(/NEW_INDEX/g, multiEntryIndex++);
          var div = document.createElement('div');
          div.innerHTML = html;
          container.appendChild(div.firstElementChild);
          attachRemoveHandlers();
        }
      });
    });

    attachRemoveHandlers();
  });

  function attachRemoveHandlers() {
    document.querySelectorAll('.remove-multi-entry').forEach(function(link) {
      link.removeEventListener('click', removeMultiEntry);
      link.addEventListener('click', removeMultiEntry);
    });
  }

  function removeMultiEntry(e) {
    e.preventDefault();
    var row = this.closest('.multi-entry-row');
    if (row) {
      var destroyInput = row.querySelector('input[name*="_destroy"]');
      if (destroyInput) {
        destroyInput.value = '1';
        row.style.display = 'none';
      } else {
        row.remove();
      }
    }
  }

  function updateLevelOfSignificance() {
    var probabilitySelect = document.getElementById('risk_probability_point');
    var impactSelect = document.getElementById('risk_impact_point');
    var significanceSpan = document.getElementById('level_of_significance_value');
    var probabilityDescSpan = document.getElementById('probability_point_description');
    var impactDescSpan = document.getElementById('impact_point_description');

    var probability = probabilitySelect ? parseInt(probabilitySelect.value) : null;
    var impact = impactSelect ? parseInt(impactSelect.value) : null;

    // Update probability description
    if (probabilityDescSpan && probability) {
      probabilityDescSpan.innerHTML = '<em class="info">' + (probabilityDescriptions[probability] || '') + '</em>';
    } else if (probabilityDescSpan) {
      probabilityDescSpan.innerHTML = '<em class="info"><%= l(:text_select_to_see_description) %></em>';
    }

    // Update impact description
    if (impactDescSpan && impact) {
      impactDescSpan.innerHTML = '<em class="info">' + (impactDescriptions[impact] || '') + '</em>';
    } else if (impactDescSpan) {
      impactDescSpan.innerHTML = '<em class="info"><%= l(:text_select_to_see_description) %></em>';
    }

    // Calculate and update level of significance
    if (probability && impact && !isNaN(probability) && !isNaN(impact)) {
      var result = probability * impact;
      significanceSpan.textContent = result;
      significanceSpan.className = 'significance-value ' + getSignificanceClass(result);
    } else {
      significanceSpan.textContent = '-';
      significanceSpan.className = 'significance-value';
    }
  }

  function getSignificanceClass(value) {
    if (value >= 12) return 'critical';
    if (value >= 8) return 'high';
    if (value >= 4) return 'medium';
    return 'low';
  }

  function toggleSection(sectionId) {
    var section = document.getElementById(sectionId);
    if (section) {
      section.classList.toggle('collapsed');
    }
  }

  function updateRiskIdPrefix() {
    var categorySelect = document.getElementById('risk_risk_category_entry_id');
    var prefixSpan = document.getElementById('risk_id_prefix');

    if (categorySelect && prefixSpan) {
      var selectedOption = categorySelect.options[categorySelect.selectedIndex];
      if (selectedOption && selectedOption.value) {
        var code = selectedOption.getAttribute('data-code');
        prefixSpan.textContent = code || '';
        prefixSpan.style.display = code ? 'inline-block' : 'none';
      } else {
        prefixSpan.textContent = '';
        prefixSpan.style.display = 'none';
      }
    }
  }

  // Initialize prefix display on page load
  document.addEventListener('DOMContentLoaded', function() {
    updateRiskIdPrefix();
  });
</script>
