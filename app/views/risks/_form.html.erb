    <input type="text" name="risk[risk_consequences_attributes][NEW_INDEX][description]" placeholder="<%= l(:field_description) %>" class="multi-entry-description" />
    <a href="#" class="icon icon-del remove-multi-entry"><%= l(:button_delete) %></a>
  </div>
</script>

<script type="text/html" id="risk_counter_measure_template">
  <div class="multi-entry-row">
    <input type="text" name="risk[risk_counter_measures_attributes][NEW_INDEX][name]" placeholder="<%= l(:field_name) %>" class="multi-entry-name" />
    <input type="text" name="risk[risk_counter_measures_attributes][NEW_INDEX][description]" placeholder="<%= l(:field_description) %>" class="multi-entry-description" />
