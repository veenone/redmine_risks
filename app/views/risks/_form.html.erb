<%= labelled_fields_for :risk, @risk do |f| %>
  <%# Section 1: Risk Identification %>
  <fieldset class="risk-section collapsible" id="risk-identification">
    <legend onclick="toggleSection('risk-identification')"><%= l(:label_risk_identification) %></legend>
    <div class="section-content">
      <div class="splitcontent">
        <div class="splitcontentleft">
          <% if @risk.safe_attribute?('risk_category_entry_id') %>
            <p>
              <% category_options = @risk.project.risk_category_entries.active.sorted.collect { |c|
                   [c.name, c.id, { 'data-code' => c.code.present? ? c.code : c.name.first.upcase }]
                 } %>
              <%= f.select :risk_category_entry_id,
                           options_for_select(category_options, @risk.risk_category_entry_id),
                           { :include_blank => true },
                           { :label => l(:field_risk_category_entry), :id => 'risk_risk_category_entry_id', :onchange => 'updateRiskIdPrefix()' } %>
            </p>
          <% end %>

          <% if @risk.safe_attribute?('risk_id_code') %>
            <p>
              <label for="risk_risk_id_code"><%= l(:field_risk_id_code) %></label>
              <span class="risk-id-input-wrapper">
                <span id="risk_id_prefix" class="risk-id-prefix"><%= @risk.risk_category_entry&.code.presence || @risk.risk_category_entry&.name&.first&.upcase || '' %></span>
                <%= text_field_tag 'risk[risk_id_code]', @risk.risk_id_code, :size => 16, :maxlength => 20, :id => 'risk_risk_id_code', :placeholder => l(:text_risk_id_placeholder) %>
              </span>
              <em class="info"><%= l(:text_risk_id_code_info) %></em>
            </p>
          <% end %>

          <% if @risk.safe_attribute?('risk_registry_id') %>
            <p>
              <%= f.select :risk_registry_id,
                           @risk.project.risk_registries.active.sorted.collect { |r| [r.name, r.id] },
                           { :include_blank => true },
                           { :label => l(:field_risk_registry) } %>
            </p>
          <% end %>
        </div>
        <div class="splitcontentright">
          <% if @risk.safe_attribute?('risk_area_id') %>
            <p>
              <%= f.select :risk_area_id,
                           @risk.project.risk_areas.active.sorted.collect { |a| [a.name, a.id] },
                           { :include_blank => true },
                           { :label => l(:field_risk_area) } %>
            </p>
          <% end %>

          <% if @risk.safe_attribute? 'status' %>
            <p><%= f.select :status, Risk::RISK_STATUS.collect {|s| [format_risk_status(s), s]} %></p>
          <% end %>
        </div>
      </div>

      <% if @risk.safe_attribute? 'subject' %>
        <p><%= f.text_field :subject, :size => 80, :maxlength => 255, :required => true %></p>
      <% end %>

      <% if @risk.safe_attribute?('threat_event') %>
        <p>
          <%= f.label_for_field :threat_event %>
          <%= f.text_area :threat_event,
                          :cols => 60,
                          :rows => 3,
                          :class => 'wiki-edit' %>
          <em class="info"><%= l(:text_threat_event_info) %></em>
        </p>
      <% end %>

      <% if @risk.safe_attribute? 'description' %>
        <p>
          <%= f.label_for_field :description %>
          <%= link_to_function content_tag(:span, l(:button_edit), :class => 'icon icon-edit'), '$(this).hide(); $("#risk_description_and_toolbar").show()' unless @risk.new_record? %>
          <%= content_tag 'span', :id => "risk_description_and_toolbar", :style => (@risk.new_record? ? nil : 'display:none') do %>
            <%= f.text_area :description,
                            :cols => 60,
                            :rows => [[10, @risk.description.to_s.length / 50].max, 20].min,
                            :accesskey => accesskey(:edit),
                            :class => 'wiki-edit',
                            :no_label => true %>
          <% end %>
        </p>

        <% if Redmine::VERSION.to_s >= '4.0' %>
          <%= wikitoolbar_for 'risk_description', preview_new_risk_path(:project_id => @risk.project) %>
        <% else %>
          <%= wikitoolbar_for 'risk_description' %>
        <% end %>
      <% end %>
    </div>
  </fieldset>

  <%# Section 2: Risk Ownership %>
  <fieldset class="risk-section collapsible" id="risk-ownership">
    <legend onclick="toggleSection('risk-ownership')"><%= l(:label_risk_ownership) %></legend>
    <div class="section-content">
      <div class="splitcontent">
        <div class="splitcontentleft">
          <% if @risk.safe_attribute?('risk_owner_id') %>
            <p>
              <%= f.label_for_field :risk_owner_id %>
              <%= f.select :risk_owner_id, principals_options_for_select(@risk.assignable_users, @risk.risk_owner),
                           :include_blank => true %>
              <em class="info"><%= l(:text_risk_owner_info) %></em>
            </p>
          <% end %>

          <% if @risk.safe_attribute? 'assigned_to_id' %>
            <p><%= f.select :assigned_to_id, principals_options_for_select(@risk.assignable_users, @risk.assigned_to), :include_blank => true %></p>
          <% end %>
        </div>
        <div class="splitcontentright">
          <% if @risk.safe_attribute?('action_owner_id') %>
            <p>
              <%= f.label_for_field :action_owner_id %>
              <%= f.select :action_owner_id, principals_options_for_select(@risk.assignable_users, @risk.action_owner),
                           :include_blank => true %>
              <em class="info"><%= l(:text_action_owner_info) %></em>
            </p>
          <% end %>

          <% if @risk.safe_attribute? 'owner_id' %>
            <p><%= f.select :owner_id, principals_options_for_select(@risk.assignable_owners, @risk.owner), :include_blank => true %></p>
          <% end %>
        </div>
      </div>
    </div>
  </fieldset>

  <%# Section 3: Impacted Assets (Multi-entry) %>
  <fieldset class="risk-section collapsible" id="risk-assets">
    <legend onclick="toggleSection('risk-assets')"><%= l(:label_impacted_assets) %></legend>
    <div class="section-content">
      <p class="section-description"><%= l(:text_impacted_assets_multi_info) %></p>
      <div id="risk_assets_container" class="multi-entry-container">
        <%= render partial: 'risks/multi_entry_fields', locals: { f: f, association: :risk_assets, field_name: 'risk_assets' } %>
      </div>
      <p>
        <a href="#" class="icon icon-add add-multi-entry" data-container="risk_assets_container" data-template="risk_asset_template">
          <%= l(:button_add_asset) %>
        </a>
      </p>
    </div>
  </fieldset>

  <%# Section 4: Vulnerabilities (Multi-entry) %>
  <fieldset class="risk-section collapsible" id="risk-vulnerabilities">
    <legend onclick="toggleSection('risk-vulnerabilities')"><%= l(:label_vulnerabilities) %></legend>
    <div class="section-content">
      <p class="section-description"><%= l(:text_vulnerabilities_multi_info) %></p>
      <div id="risk_vulnerabilities_container" class="multi-entry-container">
        <%= render partial: 'risks/multi_entry_fields', locals: { f: f, association: :risk_vulnerabilities, field_name: 'risk_vulnerabilities' } %>
      </div>
      <p>
        <a href="#" class="icon icon-add add-multi-entry" data-container="risk_vulnerabilities_container" data-template="risk_vulnerability_template">
          <%= l(:button_add_vulnerability) %>
        </a>
      </p>
    </div>
  </fieldset>

  <%# Section 5: Consequences (Multi-entry) %>
  <fieldset class="risk-section collapsible" id="risk-consequences">
    <legend onclick="toggleSection('risk-consequences')"><%= l(:label_consequences) %></legend>
    <div class="section-content">
      <p class="section-description"><%= l(:text_consequences_multi_info) %></p>
      <div id="risk_consequences_container" class="multi-entry-container">
        <%= render partial: 'risks/multi_entry_fields', locals: { f: f, association: :risk_consequences, field_name: 'risk_consequences' } %>
      </div>
      <p>
        <a href="#" class="icon icon-add add-multi-entry" data-container="risk_consequences_container" data-template="risk_consequence_template">
          <%= l(:button_add_consequence) %>
        </a>
      </p>
    </div>
  </fieldset>

  <%# Section 6: Counter-measures (Multi-entry) %>
  <fieldset class="risk-section collapsible" id="risk-counter-measures">
    <legend onclick="toggleSection('risk-counter-measures')"><%= l(:label_counter_measures) %></legend>
    <div class="section-content">
      <p class="section-description"><%= l(:text_counter_measures_multi_info) %></p>
      <div id="risk_counter_measures_container" class="multi-entry-container">
        <%= render partial: 'risks/multi_entry_fields', locals: { f: f, association: :risk_counter_measures, field_name: 'risk_counter_measures' } %>
      </div>
      <p>
        <a href="#" class="icon icon-add add-multi-entry" data-container="risk_counter_measures_container" data-template="risk_counter_measure_template">
          <%= l(:button_add_counter_measure) %>
        </a>
      </p>
    </div>
  </fieldset>

  <%# Section 7: CIA Assessment %>
  <% risk_project_setting = RiskProjectSetting.for_project(@risk.project) %>
  <fieldset class="risk-section collapsible" id="risk-cia">
    <legend onclick="toggleSection('risk-cia')"><%= l(:label_risk_cia_assessment) %></legend>
    <div class="section-content">
      <p class="section-description"><%= l(:text_cia_assessment_description) %></p>
      <% if risk_project_setting.boolean_cia_mode? %>
        <p class="cia-mode-indicator"><em class="info"><%= l(:text_cia_boolean_mode_active) %></em></p>
      <% end %>

      <div class="cia-grid">
        <% if @risk.safe_attribute?('confidentiality') %>
          <div class="cia-item">
            <div class="cia-header confidentiality">
              <span class="cia-icon">C</span>
              <span class="cia-label"><%= l(:field_confidentiality) %></span>
            </div>
            <%= select_tag 'risk[confidentiality]',
                           options_for_select([[l(:label_please_select), nil]] + Risk.cia_options_for_project(@risk.project, :confidentiality), @risk.confidentiality),
                           :id => 'risk_confidentiality' %>
          </div>
        <% end %>

        <% if @risk.safe_attribute?('integrity') %>
          <div class="cia-item">
            <div class="cia-header integrity">
              <span class="cia-icon">I</span>
              <span class="cia-label"><%= l(:field_integrity) %></span>
            </div>
            <%= select_tag 'risk[integrity]',
                           options_for_select([[l(:label_please_select), nil]] + Risk.cia_options_for_project(@risk.project, :integrity), @risk.integrity),
                           :id => 'risk_integrity' %>
          </div>
        <% end %>

        <% if @risk.safe_attribute?('availability') %>
          <div class="cia-item">
            <div class="cia-header availability">
              <span class="cia-icon">A</span>
              <span class="cia-label"><%= l(:field_availability) %></span>
            </div>
            <%= select_tag 'risk[availability]',
                           options_for_select([[l(:label_please_select), nil]] + Risk.cia_options_for_project(@risk.project, :availability), @risk.availability),
                           :id => 'risk_availability' %>
          </div>
        <% end %>
      </div>
    </div>
  </fieldset>

  <%# Section 8: Risk Assessment (Impact & Probability) %>
  <fieldset class="risk-section collapsible" id="risk-assessment">
    <legend onclick="toggleSection('risk-assessment')"><%= l(:label_risk_assessment) %></legend>
    <div class="section-content">
      <p class="section-description"><%= l(:text_risk_significance_description) %></p>

      <div class="significance-grid">
        <div class="significance-item">
          <% if @risk.safe_attribute?('impact_point') %>
            <div class="field-group">
              <span class="field-label"><%= l(:field_impact_point) %></span>
              <%= select_tag 'risk[impact_point]',
                             options_for_select([[l(:label_please_select), nil]] + Risk.impact_point_options, @risk.impact_point),
                             :id => 'risk_impact_point',
                             :onchange => 'updateLevelOfSignificance()' %>
            </div>
            <div class="field-description" id="impact_point_description">
              <em class="info"><%= @risk.impact_point.present? ? Risk.impact_point_description(@risk.impact_point) : l(:text_select_to_see_description) %></em>
            </div>
          <% end %>
        </div>

        <div class="significance-item">
          <% if @risk.safe_attribute?('probability_point') %>
            <div class="field-group">
              <span class="field-label"><%= l(:field_probability_point) %></span>
              <%= select_tag 'risk[probability_point]',
                             options_for_select([[l(:label_please_select), nil]] + Risk.probability_point_options, @risk.probability_point),
                             :id => 'risk_probability_point',
                             :onchange => 'updateLevelOfSignificance()' %>
            </div>
            <div class="field-description" id="probability_point_description">
              <em class="info"><%= @risk.probability_point.present? ? Risk.probability_point_description(@risk.probability_point) : l(:text_select_to_see_description) %></em>
            </div>
          <% end %>
        </div>

        <div class="significance-result">
          <div class="result-box">
            <span class="result-label"><%= l(:field_level_of_significance) %></span>
            <span class="significance-value" id="level_of_significance_value"><%= @risk.level_of_significance.present? ? @risk.level_of_significance : '-' %></span>
            <em class="info"><%= l(:text_significance_calculation_info) %></em>
          </div>
        </div>
      </div>

      <div class="splitcontent" style="margin-top: 15px;">
        <div class="splitcontentleft">
          <% if @risk.safe_attribute?('probability') %>
            <p><%= f.select :probability, format_risk_levels(Risk::RISK_PROBABILITY, @risk.probability) {|p| format_risk_probability(p)}, :include_blank => true %></p>
          <% end %>

          <% if @risk.safe_attribute?('impact') %>
            <p><%= f.select :impact, format_risk_levels(Risk::RISK_IMPACT, @risk.impact) {|i| format_risk_impact(i)}, :include_blank => true %></p>
          <% end %>
        </div>
        <div class="splitcontentright">
          <% if @risk.safe_attribute?('strategy') %>
            <p><%= f.select :strategy, Risk::RISK_STRATEGY.collect {|p| [format_risk_strategy(p), p]}, :include_blank => true %></p>
          <% end %>

          <% if @risk.probability.present? && @risk.impact.present? %>
            <p>
              <label><%= l(:field_magnitude) %></label>
              <span class="value magnitude-badge <%= @risk.magnitude.to_s.downcase %>"><%= @risk.magnitude %></span>
            </p>
          <% end %>
        </div>
      </div>
    </div>
  </fieldset>

  <%# Section 9: Risk Treatment %>
  <fieldset class="risk-section collapsible" id="risk-treatment-section">
    <legend onclick="toggleSection('risk-treatment-section')"><%= l(:label_risk_treatment) %></legend>
    <div class="section-content">
      <p class="section-description"><%= l(:text_risk_treatment_description) %></p>

      <div class="splitcontent">
        <div class="splitcontentleft">
          <% if @risk.safe_attribute?('risk_treatment_plan') %>
            <p>
              <%= f.label_for_field :risk_treatment_plan %>
              <%= f.select :risk_treatment_plan,
                           Risk::RISK_TREATMENT_PLAN.collect {|p| [l("label_risk_treatment_plan_#{p}"), p]},
                           :include_blank => true %>
            </p>
          <% end %>
        </div>
        <div class="splitcontentright">
          <% if @risk.safe_attribute?('risk_treatment_owner_id') %>
            <p>
              <%= f.label_for_field :risk_treatment_owner_id %>
              <%= f.select :risk_treatment_owner_id, principals_options_for_select(@risk.assignable_users, @risk.risk_treatment_owner),
                           :include_blank => true %>
              <em class="info"><%= l(:text_risk_treatment_owner_info) %></em>
            </p>
          <% end %>
        </div>
      </div>

      <% if @risk.safe_attribute?('risk_treatment') %>
        <p>
          <%= f.label_for_field :risk_treatment %>
          <%= f.text_area :risk_treatment,
                          :cols => 60,
                          :rows => 6,
                          :class => 'wiki-edit' %>
          <em class="info"><%= l(:text_risk_treatment_info) %></em>
        </p>
        <%= wikitoolbar_for 'risk_risk_treatment' %>
      <% end %>
    </div>
  </fieldset>

  <%# Section 10: Risk Treatment Plan - Mitigation (Multi-entry) %>
  <fieldset class="risk-section collapsible" id="risk-mitigations">
    <legend onclick="toggleSection('risk-mitigations')"><%= l(:label_mitigations) %></legend>
    <div class="section-content">
      <p class="section-description"><%= l(:text_mitigations_info) %></p>
      <div id="risk_mitigations_container" class="multi-entry-container">
        <%= render partial: 'risks/multi_entry_fields', locals: { f: f, association: :risk_mitigations, field_name: 'risk_mitigations' } %>
      </div>
      <p>
        <a href="#" class="icon icon-add add-multi-entry" data-container="risk_mitigations_container" data-template="risk_mitigation_template">
          <%= l(:button_add_mitigation) %>
        </a>
      </p>
    </div>
  </fieldset>

  <%# Section 11: Risk Treatment Plan - Prevention (Multi-entry) %>
  <fieldset class="risk-section collapsible" id="risk-preventions">
    <legend onclick="toggleSection('risk-preventions')"><%= l(:label_preventions) %></legend>
    <div class="section-content">
      <p class="section-description"><%= l(:text_preventions_info) %></p>
      <div id="risk_preventions_container" class="multi-entry-container">
        <%= render partial: 'risks/multi_entry_fields', locals: { f: f, association: :risk_preventions, field_name: 'risk_preventions' } %>
      </div>
      <p>
        <a href="#" class="icon icon-add add-multi-entry" data-container="risk_preventions_container" data-template="risk_prevention_template">
          <%= l(:button_add_prevention) %>
        </a>
      </p>
    </div>
  </fieldset>

  <%# Section 12: Remark %>
  <fieldset class="risk-section collapsible" id="risk-remark">
    <legend onclick="toggleSection('risk-remark')"><%= l(:label_remark) %></legend>
    <div class="section-content">
      <% if @risk.safe_attribute?('remark') %>
        <p>
          <%= f.text_area :remark,
                          :cols => 60,
                          :rows => 4,
                          :class => 'wiki-edit' %>
        </p>
        <%= wikitoolbar_for 'risk_remark' %>
      <% end %>

      <% if @risk.safe_attribute?('lessons') %>
        <p>
          <%= f.label_for_field :lessons %>
          <%= f.text_area :lessons,
                          :cols => 60,
                          :rows => 4,
                          :class => 'wiki-edit' %>
          <em class="info"><%= l(:text_lessons_info) %></em>
        </p>
        <%= wikitoolbar_for 'risk_lessons' %>
      <% end %>
    </div>
  </fieldset>

  <%= call_hook(:view_risks_form_details_bottom, { :risk => @risk, :form => f }) %>
<% end %>

<%# Templates for multi-entry fields %>
<script type="text/html" id="risk_asset_template">
  <div class="multi-entry-row">
    <input type="text" name="risk[risk_assets_attributes][NEW_INDEX][name]" placeholder="<%= l(:field_name) %>" class="multi-entry-name" />
    <input type="text" name="risk[risk_assets_attributes][NEW_INDEX][description]" placeholder="<%= l(:field_description) %>" class="multi-entry-description" />
    <a href="#" class="icon icon-del remove-multi-entry"><%= l(:button_delete) %></a>
  </div>
</script>

<script type="text/html" id="risk_vulnerability_template">
  <div class="multi-entry-row">
    <input type="text" name="risk[risk_vulnerabilities_attributes][NEW_INDEX][name]" placeholder="<%= l(:field_name) %>" class="multi-entry-name" />
    <input type="text" name="risk[risk_vulnerabilities_attributes][NEW_INDEX][description]" placeholder="<%= l(:field_description) %>" class="multi-entry-description" />
    <a href="#" class="icon icon-del remove-multi-entry"><%= l(:button_delete) %></a>
  </div>
</script>

<script type="text/html" id="risk_consequence_template">
