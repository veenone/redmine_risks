<div class="contextual">
  <%= link_to l(:button_cancel), project_risk_registries_path(@project), :class => 'icon icon-cancel' %>
</div>

<h2><%= l(:label_new_risk_registry) %></h2>

<%= form_tag(project_risk_registries_path(@project), :method => :post, :id => 'risk-registry-form', :class => 'tabular') do %>
  <%= render :partial => 'form' %>

  <div class="form-actions">
    <%= submit_tag l(:button_create), :class => 'btn btn-primary' %>
    <%= submit_tag l(:button_create_and_continue), :name => 'continue', :class => 'btn' %>
    <%= link_to l(:button_cancel), project_risk_registries_path(@project), :class => 'btn btn-link' %>
  </div>
<% end %>

<% content_for :header_tags do %>
  <%= stylesheet_link_tag 'risks', :plugin => 'redmine_risks' %>
<% end %>
