                  class: 'icon icon-add' %>
      <em class="info"><%= l(:text_customize_points_info) %></em>
    </p>
  <% end %>
</fieldset>

<style>
  .point-settings-table { margin: 10px 0; }
  .point-settings-table th { text-align: left; padding: 6px 8px; }
  .point-settings-table td { padding: 4px 8px; }
  .point-settings-table input[type="text"] { margin: 0; }
  .point-settings-table .point-score { width: 50px; }
</style>
