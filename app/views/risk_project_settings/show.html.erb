<style>
  .point-settings-table { margin: 10px 0; }
  .point-settings-table th { text-align: left; padding: 6px 8px; }
  .point-settings-table td { padding: 4px 8px; }
  .point-settings-table input[type="text"] { margin: 0; }
  .point-settings-table .point-score { width: 50px; }
  .settings-table { margin: 10px 0; width: 100%; }
  .settings-table th { text-align: left; padding: 6px 8px; background: #f5f5f5; }
  .settings-table td { padding: 4px 8px; border-bottom: 1px solid #eee; }
  .settings-table input[type="text"] { margin: 0; }
  .entry-library { background: #fafafa; padding: 10px; margin: 10px 0; border-radius: 4px; }
  .entry-library-list { list-style: none; padding: 0; margin: 10px 0; }
  .entry-library-list li { padding: 5px 10px; border-bottom: 1px solid #eee; display: flex; justify-content: space-between; align-items: center; }
  .entry-library-list li:last-child { border-bottom: none; }
  .usage-count { color: #888; font-size: 0.9em; }
</style>

