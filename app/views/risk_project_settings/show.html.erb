        <%= text_field_tag 'probability_point_setting[score]', '', size: 5 %>
        <label><%= l(:field_label) %></label>
        <%= text_field_tag 'probability_point_setting[label]', '', size: 20 %>
        <label><%= l(:field_description) %></label>
        <%= text_field_tag 'probability_point_setting[description]', '', size: 40 %>
        <%= submit_tag l(:button_add), class: 'small' %>
